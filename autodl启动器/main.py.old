        self.auto_login_checkbox = QCheckBox('启动时自动登录')
        self.silent_refresh_checkbox = QCheckBox('静默自动刷新日志')
        self.visible_radio = QRadioButton('可视浏览器')
        self.headless_radio = QRadioButton('静默模式')
        self.visible_radio.setChecked(True)
        prefs_layout.addWidget(self.remember_password_checkbox)
        prefs_layout.addWidget(self.show_password_checkbox)
        prefs_layout.addWidget(self.auto_login_checkbox)
        prefs_layout.addWidget(self.visible_radio)
        prefs_layout.addWidget(self.headless_radio)
        prefs_layout.addWidget(self.silent_refresh_checkbox)
        
        self.autodl_login_button = QPushButton('登录')
        self.autodl_login_button.setObjectName('autodlLoginBtn')
        self.autodl_login_button.setStyleSheet('''
            QPushButton#autodlLoginBtn {
                background: #0969da; color: #ffffff; border-radius: 6px;
                font-weight: 600; font-size: 9pt; padding: 2px 8px; min-height: 28px;
            }
            QPushButton#autodlLoginBtn:hover { background: #0550ae; }
            QPushButton#autodlLoginBtn:disabled { background: #d0d7de; color: #8c959f; }
        ''')
        login_layout.addWidget(self.autodl_login_button)
        
        self.autodl_logout_button = QPushButton('登出')
        self.autodl_logout_button.setObjectName('autodlLogoutBtn')
        self.autodl_logout_button.setStyleSheet('''
            QPushButton#autodlLogoutBtn {
                background: #da3633; color: #ffffff; border-radius: 6px;
                font-weight: 600; font-size: 9pt; padding: 2px 8px; min-height: 28px;
            }
            QPushButton#autodlLogoutBtn:hover { background: #b91c1c; }
            QPushButton#autodlLogoutBtn:disabled { background: #d0d7de; color: #8c959f; }
        ''')
        self.autodl_logout_button.setEnabled(False)
        login_layout.addWidget(self.autodl_logout_button)

        login_layout.addStretch()
        layout.addLayout(login_layout)
        layout.addLayout(prefs_layout)
        
        # 设备表格
        self.autodl_devices_table = QTableWidget()
        self.autodl_devices_table.setColumnCount(5)
        self.autodl_devices_table.setHorizontalHeaderLabels(['备注', '设备名称', '状态', '规格', '操作'])
        self.autodl_devices_table.horizontalHeader().setStretchLastSection(True)
        self.autodl_devices_table.setAlternatingRowColors(True)
        self.autodl_devices_table.setSelectionBehavior(QAbstractItemView.SelectRows)
        # 提升可视高度，避免内容被截断
        self.autodl_devices_table.setMaximumHeight(480)
        # 列宽策略优化
        header = self.autodl_devices_table.horizontalHeader()
        header.setSectionResizeMode(0, QHeaderView.ResizeToContents)
        header.setSectionResizeMode(1, QHeaderView.ResizeToContents)
        header.setSectionResizeMode(2, QHeaderView.ResizeToContents)
        header.setSectionResizeMode(3, QHeaderView.ResizeToContents)
        header.setSectionResizeMode(4, QHeaderView.Stretch)
