        self.connect_button.setFixedHeight(34)
        self.connect_button.setMinimumWidth(132)
        self.connect_button.clicked.connect(self.toggle_connection)

        self.disconnect_button = QPushButton('断开')
        self.disconnect_button.setObjectName('disconnectBtn')
        self.disconnect_button.setFixedHeight(34)
        self.disconnect_button.setMinimumWidth(132)
        self.disconnect_button.setEnabled(False)
        self.disconnect_button.clicked.connect(self.disconnect)

        buttons_layout.addWidget(self.connect_button)
        buttons_layout.addWidget(self.disconnect_button)
