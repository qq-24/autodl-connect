        self.delete_all_button.setFixedHeight(30)

        config_layout.addWidget(self.config_label)
        config_layout.addWidget(self.config_combo, 1)
        config_layout.addWidget(self.save_config_button)
        config_layout.addWidget(self.delete_config_button)
        config_layout.addWidget(self.delete_all_button)

        # 表单
        form_widget = QWidget()
        form_layout = QFormLayout(form_widget)
        form_layout.setLabelAlignment(Qt.AlignRight | Qt.AlignVCenter)
        form_layout.setFormAlignment(Qt.AlignTop)
        form_layout.setHorizontalSpacing(12)
        form_layout.setVerticalSpacing(10)

        label_min_w = 96

        self.ssh_info_input = QLineEdit()
        self.ssh_info_input.setPlaceholderText('ssh -p 端口 用户名@主机地址')
        self.ssh_info_input.setFixedHeight(44)
        self.ssh_info_input.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)

        lbl_ssh = QLabel('SSH 连接')
        lbl_ssh.setMinimumWidth(label_min_w)
        lbl_ssh.setStyleSheet('font-weight: 600;')
        form_layout.addRow(lbl_ssh, self.ssh_info_input)

        self.remote_port_input = QLineEdit()
        self.remote_port_input.setPlaceholderText('6006')
        self.remote_port_input.setFixedHeight(44)
        self.remote_port_input.setMaximumWidth(200)

        lbl_port = QLabel('远程端口')
        lbl_port.setMinimumWidth(label_min_w)
        lbl_port.setStyleSheet('font-weight: 600;')
        form_layout.addRow(lbl_port, self.remote_port_input)

        # 密码 + 显示
        pwd_row = QWidget()
        pwd_layout = QHBoxLayout(pwd_row)
        pwd_layout.setContentsMargins(0, 0, 0, 0)
        pwd_layout.setSpacing(8)

        self.password_input = QLineEdit()
        self.password_input.setEchoMode(QLineEdit.Password)
        self.password_input.setPlaceholderText('SSH 密码')
        self.password_input.setFixedHeight(44)
        self.password_input.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)

        self.show_password_checkbox = QCheckBox('显示')
        self.show_password_checkbox.setMinimumHeight(34)
        self.show_password_checkbox.stateChanged.connect(self.toggle_password_visibility)

        pwd_layout.addWidget(self.password_input, 1)
        pwd_layout.addWidget(self.show_password_checkbox, 0, Qt.AlignRight | Qt.AlignVCenter)

        lbl_pwd = QLabel('密码')
        lbl_pwd.setMinimumWidth(label_min_w)
        lbl_pwd.setStyleSheet('font-weight: 600;')
        form_layout.addRow(lbl_pwd, pwd_row)

        # 选项
        self.auto_open_browser_checkbox = QCheckBox('连接成功后自动打开浏览器')
        self.auto_open_browser_checkbox.setChecked(True)
        form_layout.addRow(QLabel(''), self.auto_open_browser_checkbox)


        # 操作按钮
        buttons_layout = QHBoxLayout()
        buttons_layout.setSpacing(6)

        self.connect_button = QPushButton('连接')
