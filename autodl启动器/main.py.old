    def __init__(self):
        super().__init__()
        # 确保中文显示正常
        import sys
        print(f"Python版本: {sys.version}")
        print(f"PyQt版本: {QtCore.QT_VERSION_STR if 'QtCore' in globals() else '未知'}")

        self.ssh_client = None
        self.forward_thread = None
        self.is_connected = False
        self.stop_event = threading.Event()
        self.client_threads = []
        self.server_socket = None
        self.is_connecting = False
        self.reconnecting = False
        self._last_connect_args = None
        self.refreshing = False
        self.port_forwarding_setup = False
        try:
            import threading as _th
            self.autodl_refresh_lock = _th.Lock()
        except Exception:
            self.autodl_refresh_lock = None
        self.autodl_busy = False
        self.last_auto_refresh_time = 0
        
        # 启动刷新时间更新定时器
        self.refresh_time_timer = QtCore.QTimer(self)
        self.refresh_time_timer.setInterval(1000)
        self.refresh_time_timer.timeout.connect(self._update_refresh_time_label)
        self.refresh_time_timer.start()
        
        # 设置AppUserModelID以修复任务栏图标
        try:
            ctypes.windll.shell32.SetCurrentProcessExplicitAppUserModelID("my.autodl.helper.1.0")
        except Exception:
            pass
        
        # AutoDL相关（便携模式优先，失败时回退到用户目录）；统一配置目录
        self.autodl_driver = None
        self.is_autodl_logged_in = False
        try:
            base_dir = os.path.dirname(sys.executable) if getattr(sys, 'frozen', False) else os.path.dirname(os.path.abspath(__file__))
        except Exception:
            base_dir = os.path.dirname(os.path.abspath(__file__))
        self.portable_base_dir = base_dir
        # 统一配置目录
        self.config_dir = os.path.join(self.portable_base_dir, 'configs')
        print(f"配置目录: {self.config_dir}")
        self._init_config_directory()
        self.current_theme = 'light'
        try:
            self._load_theme_pref()
        except Exception:
            pass
        self.await_running_device_id = None
        self.await_running_remark = None
        self.await_running_deadline = None
        self.last_device_hash = None
        # 加载加密偏好
        self.encryption_enabled = False
        self._load_encryption_pref()
        self.encryption_prompted = False
        self._load_encryption_prompted()
        # 将 AutoDL 配置文件统一放在同一目录下
        self.autodl_config_dir = self.config_dir
        self.autodl_credentials_file = os.path.join(self.config_dir, 'autodl_credentials.json')
        # 迁移旧 autodl_configs 目录中的文件
        self._migrate_autodl_configs_to_unified()
        self.device_map_file = os.path.join(self.config_dir, 'device_map.json')
        self.readme_path = self._ensure_readme_file()
        self.setup_ui()
        try:
            self._load_browser_prefs()
        except Exception:
            pass
        self.setup_event_handlers()
        # 加载保存的配置列表
        self.load_config_list()
        # 加载保存的AutoDL凭据
        self.load_autodl_credentials()
        try:
            self.apply_theme()
        except Exception:
            pass
        try:
            if SELENIUM_AVAILABLE and self.auto_login_checkbox.isChecked():
                QtCore.QTimer.singleShot(100, lambda: self.autodl_login(None))
        except Exception:
            pass
        # 初始化删除按钮状态
        self.update_delete_button_state()
        print("程序初始化完成")

    def _init_config_directory(self):
        """初始化配置目录（便携模式优先，失败回退用户目录），加强权限提示"""
        try:
            if not os.path.exists(self.config_dir):
                os.makedirs(self.config_dir, exist_ok=True)
                self.update_status_signal.emit(f'配置目录已创建: {self.config_dir}')
        except PermissionError as e:
            self.update_status_signal.emit(f'权限不足: 无法创建程序目录的配置文件 ({str(e)})，已回退到用户目录')
            self.config_dir = os.path.join(os.path.expanduser('~'), '.ssh_port_forwarder', 'configs')
            try:
                os.makedirs(self.config_dir, exist_ok=True)
                self.update_status_signal.emit(f'已使用用户目录: {self.config_dir}')
            except Exception as e2:
                self.update_status_signal.emit(f'严重警告: 无法创建用户目录配置: {str(e2)}')
                self.config_dir = None
        except Exception as e:
            self.update_status_signal.emit(f'警告: 创建配置目录出错: {str(e)}，尝试使用用户目录')
            self.config_dir = os.path.join(os.path.expanduser('~'), '.ssh_port_forwarder', 'configs')
            try:
                os.makedirs(self.config_dir, exist_ok=True)
                self.update_status_signal.emit(f'已使用用户目录: {self.config_dir}')
            except Exception as e2:
                self.update_status_signal.emit(f'严重警告: 无法创建用户目录配置: {str(e2)}')
                self.config_dir = None

    def _migrate_autodl_configs_to_unified(self):
        try:
            old_dir = os.path.join(self.portable_base_dir, 'autodl_configs')
            if os.path.isdir(old_dir):
                # 迁移 credentials.json
                try:
                    name = 'credentials.json'
                    src = os.path.join(old_dir, name)
                    if os.path.exists(src):
                        dst = os.path.join(self.config_dir, 'autodl_credentials.json')
                        # 仅当目标文件不存在时才迁移，避免覆盖用户的新设置
                        if not os.path.exists(dst):
                            os.makedirs(self.config_dir, exist_ok=True)
                            import shutil
                            shutil.copyfile(src, dst)
                            self.update_status_signal.emit('已迁移 credentials.json 到统一配置目录')
                            print(f"DEBUG: 迁移旧配置 {src} -> {dst}")
                        else:
                            print(f"DEBUG: 跳过迁移，目标文件已存在: {dst}")
                except Exception:
                    pass
                
                # 迁移 cookies.json
                try:
                    name = 'cookies.json'
                    src = os.path.join(old_dir, name)
                    if os.path.exists(src):
                        dst = os.path.join(self.config_dir, 'autodl_cookies.json')
                        if not os.path.exists(dst):
                            os.makedirs(self.config_dir, exist_ok=True)
                            import shutil
                            shutil.copyfile(src, dst)
                            self.update_status_signal.emit('已迁移 cookies.json 到统一配置目录')
                except Exception:
                    pass
        except Exception:
            pass
    def _get_readme_source_path(self):
        try:
            base = getattr(sys, '_MEIPASS', None)
            if base:
                p = os.path.join(base, 'README.md')
                if os.path.exists(p):
                    return p
        except Exception:
            pass
        try:
            p = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'README.md')
            if os.path.exists(p):
                return p
        except Exception:
            pass
        return None

    def _ensure_readme_file(self):
        try:
            target = os.path.join(self.portable_base_dir, 'README.md')
            if os.path.exists(target):
                return target
            
            # 异步复制README文件，避免阻塞主线程
            def copy_readme_async():
                try:
                    src = self._get_readme_source_path()
                    if src and os.path.exists(src):
                        import shutil
                        try:
                            shutil.copyfile(src, target)
                        except Exception:
                            pass
                    if not os.path.exists(target):
                        try:
                            with open(target, 'w', encoding='utf-8') as f:
                                f.write('AutoDL 一键连接使用说明\n\n- 在左侧填写 SSH 信息与端口后保存配置\n- 点击连接按钮建立端口转发\n- 问号按钮打开本说明文件\n')
                        except Exception:
                            pass
                except Exception:
                    pass
            
            # 使用线程异步执行，避免阻塞主UI线程
            import threading
            t = threading.Thread(target=copy_readme_async, daemon=True)
            t.start()
            
            return target
        except Exception:
            return os.path.join(self.portable_base_dir, 'README.md')

    def _encryption_pref_path(self):
        try:
            return os.path.join(self.config_dir or self.portable_base_dir, 'encryption_enabled.flag')
        except Exception:
            return os.path.join(self.portable_base_dir, 'encryption_enabled.flag')

    def _load_encryption_pref(self):
        try:
            p = self._encryption_pref_path()
            if os.path.exists(p):
                with open(p, 'r', encoding='utf-8') as f:
                    v = f.read().strip()
                    self.encryption_enabled = (v == '1')
        except Exception:
            pass

    def _set_encryption_pref(self, enabled):
        try:
            self.encryption_enabled = bool(enabled)
            p = self._encryption_pref_path()
            os.makedirs(os.path.dirname(p), exist_ok=True)
            with open(p, 'w', encoding='utf-8') as f:
                f.write('1' if self.encryption_enabled else '0')
        except Exception:
            pass

    def _encryption_prompted_path(self):
        try:
            return os.path.join(self.config_dir or self.portable_base_dir, 'encryption_prompted.flag')
        except Exception:
            return os.path.join(self.portable_base_dir, 'encryption_prompted.flag')

    def _load_encryption_prompted(self):
        try:
            p = self._encryption_prompted_path()
            if os.path.exists(p):
                with open(p, 'r', encoding='utf-8') as f:
                    v = f.read().strip()
                    self.encryption_prompted = (v == '1')
        except Exception:
            pass

    def _set_encryption_prompted(self, prompted):
        try:
            self.encryption_prompted = bool(prompted)
            p = self._encryption_prompted_path()
            os.makedirs(os.path.dirname(p), exist_ok=True)
            with open(p, 'w', encoding='utf-8') as f:
                f.write('1' if self.encryption_prompted else '0')
        except Exception:
            pass

    def _is_ui_thread(self):
        try:
            app = QApplication.instance()
            if not app:
                return False
            return QtCore.QThread.currentThread() == app.thread()
        except Exception:
            return False

    def open_readme(self):
        try:
            p = self.readme_path or os.path.join(self.portable_base_dir, 'README.md')
            if not os.path.exists(p):
                p = self._ensure_readme_file()
            if p and os.path.exists(p):
                QDesktopServices.openUrl(QUrl.fromLocalFile(p))
            else:
                try:
                    os.startfile(p)
                except Exception:
                    pass
        except Exception:
            pass
    
    def save_autodl_credentials(self, username=None, password=None):
        """保存AutoDL登录凭据"""
        try:
            if username is None:
                username = self.autodl_username_input.text().strip()
            if password is None:
                password = self.autodl_password_input.text()

            remember = self.remember_password_checkbox.isChecked()
            
            if not username:
                print("DEBUG: 用户名为空，跳过保存")
                return
            
            pwd_to_save = password if remember else ''
            
            # 强制启用加密保存
            try:
                if pwd_to_save:
                    enc = _win_dpapi_encrypt(pwd_to_save)
                    if enc:
                        pwd_to_save = enc
            except Exception:
                pass
                
            print(f"DEBUG: 正在保存密码(已脱敏): {'******' if pwd_to_save else 'Empty'}")
            print(f"DEBUG: 配置文件路径: {self.autodl_credentials_file}")

            credentials = {
                'username': username,
                'password': pwd_to_save,
                'remember_password': remember,
                'show_password': bool(self.show_password_checkbox.isChecked()),
                'auto_login': bool(self.auto_login_checkbox.isChecked()),
                'silent_refresh': bool(self.silent_refresh_checkbox.isChecked()),
                'theme': getattr(self, 'current_theme', 'light'),
                'saved_at': time.strftime('%Y-%m-%d %H:%M:%S')
            }
            
            with open(self.autodl_credentials_file, 'w', encoding='utf-8') as f:
                json.dump(credentials, f, ensure_ascii=False, indent=2)
            
            # [新增] 验证保存结果
            try:
                with open(self.autodl_credentials_file, 'r', encoding='utf-8') as f:
                    saved_data = json.load(f)
                if saved_data.get('password') != pwd_to_save:
                    print("CRITICAL: 密码保存验证失败！")
                    self.autodl_status_signal.emit('警告：密码保存失败，请重试！')
                else:
                    print(f"AutoDL凭据已保存并验证: {username}")
                    self.autodl_status_signal.emit('登录凭据已保存')
            except Exception as e:
                print(f"验证保存结果失败: {e}")
            try:
                self._save_theme_pref()
            except Exception:
                pass
            
        except Exception as e:
            print(f"保存AutoDL凭据失败: {e}")

    def _persist_login_prefs(self):
        """仅保存UI偏好设置，不修改账号密码"""
        try:
            # 如果没有配置文件，不创建空的（防止覆盖）
            if not os.path.exists(self.autodl_credentials_file):
                return

            credentials = {}
            try:
                with open(self.autodl_credentials_file, 'r', encoding='utf-8') as f:
                    credentials = json.load(f)
            except Exception:
                return # 读取失败也不要覆盖

            # 仅更新偏好设置字段，严格保留原有的 username/password/remember_password
            credentials['auto_login'] = bool(self.auto_login_checkbox.isChecked())
            credentials['show_password'] = bool(self.show_password_checkbox.isChecked())
            credentials['silent_refresh'] = bool(self.silent_refresh_checkbox.isChecked())
            credentials['theme'] = getattr(self, 'current_theme', 'light')
            
            # 再次确保 username/password 不会被 None 覆盖
            if 'username' not in credentials:
                credentials['username'] = self.autodl_username_input.text().strip()
            
            # 写入文件
            with open(self.autodl_credentials_file, 'w', encoding='utf-8') as f:
                json.dump(credentials, f, ensure_ascii=False, indent=2)
                
            try:
                self._save_theme_pref()
            except Exception:
                pass
            try:
                self._save_browser_prefs()
            except Exception:
                pass
        except Exception:
            pass
    
    def load_autodl_credentials(self):
        """加载AutoDL登录凭据"""
        try:
            if os.path.exists(self.autodl_credentials_file):
                print(f"DEBUG: 正在加载配置文件: {self.autodl_credentials_file}")
                with open(self.autodl_credentials_file, 'r', encoding='utf-8') as f:
                    credentials = json.load(f)
                # 加载通用偏好（不依赖记住密码）
                try:
                    self.auto_login_checkbox.setChecked(bool(credentials.get('auto_login', False)))
                    self.show_password_checkbox.setChecked(bool(credentials.get('show_password', False)))
                    self.silent_refresh_checkbox.setChecked(bool(credentials.get('silent_refresh', True)))
                    theme = credentials.get('theme', None)
                    if not theme:
                        try:
                            settings = QtCore.QSettings('ssh_port_forwarder', 'prefs')
                            v = settings.value('ui/theme', type=str)
                            theme = v if v in ['dark', 'light'] else 'light'
                        except Exception:
                            theme = 'light'
                    self.current_theme = theme
                except Exception:
                    pass

                # 加载用户名/密码（仅在记住密码时）
                if credentials.get('remember_password', False):
                    username = credentials.get('username', '')
                    password = credentials.get('password', '')
                    if username:
                        self.autodl_username_input.setText(username)
                    if password:
                        print(f"DEBUG: 从文件加载的原始密码字段: {password}")
                        try:
                            dec = _win_dpapi_decrypt(password)
                            if dec is not None:
                                password = dec
                                print(f"DEBUG: 解密成功: {password}")
                            else:
                                print("DEBUG: 无需解密或解密返回None")
                        except Exception as e:
                            print(f"DEBUG: 解密异常: {e}")
                            pass
                        self.autodl_password_input.setText(password)
                    self.remember_password_checkbox.setChecked(True)
                    print(f"AutoDL凭据已加载: {username}")
                    return True
            
        except Exception as e:
            print(f"加载AutoDL凭据失败: {e}")
        
        return False

    def setup_ui(self):
        # 标题、尺寸、无边框、透明背景
        self.setWindowTitle('AutoDL 一键连接')
        self.setObjectName('AppWindow')
        self.setMinimumSize(880, 800)
        self.setGeometry(200, 200, 1000, 900)
        import platform as _plat
        _sys = _plat.system().lower()
        _is_win = 'windows' in _sys
        if not _is_win:
            self.setWindowFlags(Qt.FramelessWindowHint)
            self.setAttribute(Qt.WA_TranslucentBackground)
        else:
            try:
                self.setWindowFlag(Qt.WindowCloseButtonHint, True)
            except Exception:
                pass
        self.oldPos = self.pos()
        try:
            icon_path = None
            if hasattr(sys, '_MEIPASS'):
                p = os.path.join(sys._MEIPASS, 'assets', 'icon.ico')
                if os.path.exists(p):
                    icon_path = p
            if not icon_path:
                p = os.path.join(self.portable_base_dir, 'assets', 'icon.ico')
                if os.path.exists(p):
                    icon_path = p
            if icon_path:
                self.setWindowIcon(QIcon(icon_path))
        except Exception:
            pass

        # 中央容器（保持透明，避免覆盖边框与投影）
        central = QWidget()
        central.setObjectName('central')
        central.setAttribute(Qt.WA_TranslucentBackground)
        self.setCentralWidget(central)

        # 全局（本窗口）字体：mac 用苹方，其他平台用易读无衬线，避免回退宋体
        import platform
        system = platform.system().lower()
        if 'darwin' in system:
            ui_font = QFont('PingFang SC', 13)
        elif 'windows' in system:
            ui_font = QFont('Microsoft YaHei UI', 12)
        else:
            ui_font = QFont('Noto Sans CJK SC', 12)
        central.setFont(ui_font)

        # 根布局（透明）
        root_layout = QVBoxLayout(central)
        root_layout.setContentsMargins(18, 18, 18, 18)
        root_layout.setSpacing(0)

        # 内容卡片（白底、边框、圆角 + 投影）
        content_card = QWidget()
        content_card.setObjectName('contentCard')
        card_layout = QVBoxLayout(content_card)
        card_layout.setContentsMargins(0, 0, 0, 0)
        card_layout.setSpacing(0)

        # 阴影
        if 'windows' not in system:
            shadow = QGraphicsDropShadowEffect(self)
            shadow.setBlurRadius(28)
            shadow.setColor(QColor(0, 0, 0, 60))
            shadow.setOffset(0, 8)
            content_card.setGraphicsEffect(shadow)

        # 标题栏（卡片内）
        title_bar = QWidget()
        title_bar.setObjectName('titleBar')
        title_layout = QHBoxLayout(title_bar)
        title_layout.setContentsMargins(14, 10, 10, 10)
        title_layout.setSpacing(8)

        title_label = QLabel('AutoDL 一键连接')
        title_label.setStyleSheet('font-size: 20px; font-weight: 700;')
        title_layout.addWidget(title_label)
        title_layout.addStretch()
        try:
            self.theme_button = QToolButton()
            self.theme_button.setText('🌙')
            self.theme_button.setFixedSize(24, 24)
            self.theme_button.setStyleSheet('QToolButton { background: #eff3f6; border: 1px solid #d0d7de; border-radius: 12px; color: #57606a; font-weight: 700; } QToolButton:hover { background: #e7ebef; }')
            self.theme_button.clicked.connect(self.toggle_theme)
            title_layout.addWidget(self.theme_button, 0, Qt.AlignRight | Qt.AlignVCenter)
            self.help_button = QToolButton()
            self.help_button.setText('?')
            self.help_button.setFixedSize(24, 24)
            self.help_button.setStyleSheet('QToolButton { background: #eff3f6; border: 1px solid #d0d7de; border-radius: 12px; color: #57606a; font-weight: 700; } QToolButton:hover { background: #e7ebef; }')
            self.help_button.clicked.connect(self.open_readme)
            title_layout.addWidget(self.help_button, 0, Qt.AlignRight | Qt.AlignVCenter)
        except Exception:
            pass

        card_layout.addWidget(title_bar)

        # 内容区（左右分栏）
        body = QWidget()
        body_layout = QVBoxLayout(body)
        body_layout.setContentsMargins(16, 14, 16, 16)
        body_layout.setSpacing(10)

        splitter = QSplitter(Qt.Horizontal)
        body_layout.addWidget(splitter, 1)

        # 左侧面板（AutoDL 一键连接）
        left_panel = QWidget()
