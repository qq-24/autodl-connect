    def _load_theme_pref(self):
        try:
            settings = QtCore.QSettings('ssh_port_forwarder', 'prefs')
            v = settings.value('ui/theme', type=str)
            if v in ['dark', 'light']:
                self.current_theme = v
        except Exception:
            pass

    def _save_theme_pref(self):
        try:
            settings = QtCore.QSettings('ssh_port_forwarder', 'prefs')
            settings.setValue('ui/theme', getattr(self, 'current_theme', 'light'))
        except Exception:
            pass

    def _load_browser_prefs(self):
        try:
            settings = QtCore.QSettings('ssh_port_forwarder', 'prefs')
            hv = settings.value('browser/headless', type=bool)
            sr = settings.value('refresh/silent', type=bool)
            al = settings.value('browser/auto_login', type=bool)
            if hv is not None:
                try:
                    self.headless_radio.setChecked(bool(hv))
                    self.visible_radio.setChecked(not bool(hv))
                except Exception:
                    pass
            if sr is not None:
                try:
                    self.silent_refresh_checkbox.setChecked(bool(sr))
                except Exception:
                    pass
            if al is not None:
                try:
                    self.auto_login_checkbox.setChecked(bool(al))
                except Exception:
                    pass
        except Exception:
            pass

    def _save_browser_prefs(self):
        try:
            settings = QtCore.QSettings('ssh_port_forwarder', 'prefs')
            try:
                settings.setValue('browser/headless', bool(self.headless_radio.isChecked()))
            except Exception:
                pass
            try:
                settings.setValue('refresh/silent', bool(self.silent_refresh_checkbox.isChecked()))
            except Exception:
                pass
            try:
                settings.setValue('browser/auto_login', bool(self.auto_login_checkbox.isChecked()))
            except Exception:
                pass
        except Exception:
            pass

    def connect(self):
        """建立SSH连接并设置端口转发"""
        try:
            if self.is_connected:
                self.update_status_signal.emit('已连接，忽略重复连接请求')
                return
            if self.is_connecting:
                self.update_status_signal.emit('正在连接中，请稍候')
                return
            ssh_info = self.ssh_info_input.text().strip()
            remote_port_text = self.remote_port_input.text().strip()
            password = self.password_input.text()

            if not ssh_info:
                QMessageBox.warning(self, '输入错误', '请输入SSH连接信息')
                return

            if not remote_port_text:
                QMessageBox.warning(self, '输入错误', '请输入远程端口')
                return

            try:
                remote_port = int(remote_port_text)
                if remote_port <= 0 or remote_port > 65535:
                    raise ValueError()
            except ValueError:
                QMessageBox.warning(self, '输入错误', '请输入有效的端口号')
                return

            host, port, username = self.parse_ssh_info(ssh_info)
            if not host or not username:
                QMessageBox.warning(self, '输入错误', '无法解析SSH连接信息，请检查格式\n例如: ssh -p 53372 root@region-41.seetacloud.com')
                return

            host = host.split()[0]

            self.is_connecting = True
            self.forward_thread = threading.Thread(
                target=self._connect_thread,
                args=(host, port, username, password, remote_port)
            )
            self.forward_thread.daemon = True
            self.forward_thread.start()
        except Exception as e:
            QMessageBox.critical(self, '错误', f'启动连接过程中出错: {str(e)}')

    def _connect_thread(self, host, port, username, password, remote_port):
        """在新线程中执行SSH连接和端口转发"""
        try:
            try:
                self.stop_event.clear()
            except Exception:
                pass
            self.update_status_signal.emit(f'正在连接到 {username}@{host}:{port}...')
            try:
                self._last_connect_args = (host, port, username, password, remote_port)
            except Exception:
                pass

            try:
                logging.getLogger('paramiko').setLevel(logging.WARNING)
            except Exception:
                pass

            self.ssh_client = paramiko.SSHClient()
            self.update_status_signal.emit('自动接受主机密钥（相当于输入yes）')
            self.ssh_client.set_missing_host_key_policy(paramiko.AutoAddPolicy())

            self.update_status_signal.emit('正在进行密码认证...')
            self.ssh_client.connect(
                hostname=host,
                port=int(port),
                username=username,
                password=password,
                look_for_keys=False,
                allow_agent=False,
                timeout=30
            )

            self.update_status_signal.emit('SSH连接成功')

            transport = self.ssh_client.get_transport()
            if not transport:
                raise Exception('无法获取SSH传输通道')
            try:
                transport.set_keepalive(30)
            except Exception:
                pass

            self.update_status_signal.emit(f'正在设置端口转发: 本地端口 {remote_port} -> 远程端口 {remote_port}')

            self.connection_status_signal.emit(True)
            self.is_connected = True
            try:
                self.is_connecting = False
            except Exception:
                pass

            try:
                server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                server_socket.bind(('127.0.0.1', remote_port))
                server_socket.listen(5)
                server_socket.settimeout(1)
                self.update_status_signal.emit(f'本地监听器已启动在端口 {remote_port}')
                try:
                    self.server_socket = server_socket
                except Exception:
                    pass
            except Exception as e:
                self.update_status_signal.emit(f'本地端口监听失败: 端口可能被占用或权限不足: {str(e)}')
                self.connection_status_signal.emit(False)
                return

            if self.auto_open_browser_checkbox.isChecked():
                self.port_forwarding_setup = True
                self.update_status_signal.emit('等待端口转发完全建立...')
                ready = False
                start_t = time.time()
                attempt = 0
                while (time.time() - start_t < 300) and (not self.stop_event.is_set()) and self.is_connected:
                    try:
                        t = None
                        try:
                            t = self.ssh_client.get_transport()
                        except Exception:
                            t = None
                        if t and t.is_active():
                            try:
                                ch = t.open_channel('direct-tcpip', ('127.0.0.1', remote_port), ('127.0.0.1', 0))
                                if ch:
                                    try:
                                        ch.close()
                                    except Exception:
                                        pass
                                    ready = True
                                    break
                            except Exception:
                                pass
                    except Exception:
                        pass
                    attempt += 1
                    sleep_interval = 0.5 + min(attempt * 0.25, 2.0)
                    time.sleep(sleep_interval)
                if ready:
                    url = f'http://127.0.0.1:{remote_port}'
                    self.update_status_signal.emit(f'正在打开浏览器: {url}')
                    try:
                        success = webbrowser.open(url)
                        if success:
                            self.update_status_signal.emit(f'浏览器已成功打开: {url}')
                        else:
                            self.update_status_signal.emit('无法打开浏览器，请手动访问: ' + url)
                    except Exception as e:
                        self.update_status_signal.emit(f'打开浏览器时出错: {str(e)}，请手动访问: ' + url)
                else:
                    if not self.stop_event.is_set() and self.is_connected:
                        self.update_status_signal.emit('端口转发尚未可用，未打开浏览器')
                self.port_forwarding_setup = False

            if self.is_connected and not self.stop_event.is_set():
                self.update_status_signal.emit('端口转发已设置，连接保持活跃中...')

            browser_opened = False
            if self.auto_open_browser_checkbox.isChecked():
                if ready:
                    browser_opened = True
            last_browser_try = 0.0
            while self.is_connected and not self.stop_event.is_set():
                try:
                    tcur = None
                    try:
                        tcur = self.ssh_client.get_transport()
                    except Exception:
                        tcur = None
                    if (not tcur) or (not tcur.is_active()):
                        okr = self._reconnect_in_place()
                        if not okr:
                            time.sleep(1.0)
                            continue
                        try:
                            transport = self.ssh_client.get_transport()
                        except Exception:
                            transport = None
                        if not transport or not transport.is_active():
                            time.sleep(1.0)
                            continue
                    if self.auto_open_browser_checkbox.isChecked() and not browser_opened:
                        now = time.time()
                        if now - last_browser_try >= 3.0:
                            last_browser_try = now
                            try:
                                ch2 = tcur.open_channel('direct-tcpip', ('127.0.0.1', remote_port), ('127.0.0.1', 0))
                                if ch2:
                                    try:
                                        ch2.close()
                                    except Exception:
                                        pass
                                    url2 = f'http://127.0.0.1:{remote_port}'
                                    try:
                                        okweb = webbrowser.open(url2)
                                        if okweb:
                                            self.update_status_signal.emit(f'浏览器已成功打开: {url2}')
                                        else:
                                            self.update_status_signal.emit('无法打开浏览器，请手动访问: ' + url2)
                                    except Exception as e:
                                        self.update_status_signal.emit(f'打开浏览器时出错: {str(e)}，请手动访问: ' + url2)
                                    browser_opened = True
                            except Exception:
                                pass
                    readable, _, _ = select.select([server_socket], [], [], 0.2)
                    if readable:
                        client_socket, addr = server_socket.accept()
                        try:
                            client_socket.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
                        except Exception:
                            pass
                        client_thread = threading.Thread(
                            target=self._handle_client,
                            args=(client_socket, transport, remote_port)
                        )
                        client_thread.daemon = True
                        client_thread.start()
                        try:
                            self.client_threads.append(client_thread)
                        except Exception:
                            pass
                except socket.timeout:
                    continue
                except Exception as e:
                    if self.is_connected and not self.stop_event.is_set():
                        okreb = self._recreate_server_socket(remote_port)
                        if not okreb:
                            time.sleep(1.0)
                            continue
                        try:
                            server_socket = self.server_socket
                        except Exception:
                            pass

        except paramiko.AuthenticationException:
            self.update_status_signal.emit('认证失败: 用户名或密码错误')
            self.connection_status_signal.emit(False)
        except paramiko.SSHException as e:
            self.update_status_signal.emit(f'SSH错误: {str(e)}')
            self.connection_status_signal.emit(False)
        except Exception as e:
            self.update_status_signal.emit(f'连接错误: {str(e)}')
            self.connection_status_signal.emit(False)
        finally:
            try:
                self.is_connecting = False
            except Exception:
                pass
            if 'server_socket' in locals():
                try:
                    server_socket.close()
                except:
                    pass

    def _handle_client(self, client_socket, transport, remote_port):
        """处理单个客户端连接的端口转发"""
        try:
            try:
                tt = None
                try:
                    tt = self.ssh_client.get_transport()
                except Exception:
                    tt = None
                if not tt or not tt.is_active():
                    ok_re = self._reconnect_in_place()
                    if ok_re:
                        try:
                            tt = self.ssh_client.get_transport()
                        except Exception:
                            tt = None
                if not tt or not tt.is_active():
                    raise paramiko.SSHException('SSH session not active')
                channel = tt.open_channel(
                    'direct-tcpip',
                    ('127.0.0.1', remote_port),
                    ('127.0.0.1', client_socket.getsockname()[1])
                )
            except paramiko.SSHException as e:
                self.update_status_signal.emit(f'无法创建到远程端口的通道，服务器可能禁止端口转发或目标不可达: {str(e)}')
                client_socket.close()
                return

            if not channel:
                self.update_status_signal.emit('无法创建到远程服务器的通道')
                client_socket.close()
                return

            self.update_status_signal.emit(f'已建立到远程端口 {remote_port} 的转发通道')

            while self.is_connected and not self.stop_event.is_set():
                r, _, _ = select.select([client_socket, channel], [], [], 0.08)

                if client_socket in r:
                    data = client_socket.recv(4096)
                    if not data:
                        break
                    channel.send(data)

                if channel in r:
                    data = channel.recv(4096)
                    if not data:
                        break
                    client_socket.send(data)

        except Exception as e:
            if self.is_connected:
                self.update_status_signal.emit(f'客户端连接错误: {str(e)}')
        finally:
            try:
                client_socket.close()
            except:
                pass
            try:
                if 'channel' in locals():
                    channel.close()
            except:
                pass

            self.update_status_signal.emit('客户端连接已关闭')

    def _detect_device_shutdown_for_reconnect(self):
        try:
            if not getattr(self, 'autodl_driver', None) or not getattr(self, 'is_autodl_logged_in', False):
                return False
            did = getattr(self, 'await_running_device_id', None)
            rem = getattr(self, 'await_running_remark', None)
            if not did and not rem:
                return False
            try:
                self._goto_instance_list()
            except Exception:
                pass
            r = None
            if did:
                try:
                    r = self._find_row_by_device_id(did)
                except Exception:
                    r = None
            if r is None and rem:
                try:
                    r = self._find_row_by_remark(rem)
                except Exception:
                    r = None
            if r:
                try:
                    return bool(self._is_stopped_row(r))
                except Exception:
                    return False
            return False
        except Exception:
            return False

    def _reconnect_in_place(self, max_retries=10):
        try:
            if self.stop_event.is_set():
                return False
            if self.reconnecting:
                return False
            args = getattr(self, '_last_connect_args', None)
            if not args or len(args) != 5:
                return False
            self.reconnecting = True
            host, port, username, password, remote_port = args
            attempt = 0
            while attempt < max_retries:
                if self.stop_event.is_set():
                    break
                try:
                    if self._detect_device_shutdown_for_reconnect():
                        self.update_status_signal.emit('检测到设备已关机，停止重连')
                        self.reconnecting = False
                        return False
                except Exception:
                    pass
                try:
                    if attempt == 0:
                        time.sleep(min(2 ** attempt, 60))
                except Exception:
                    pass
                c = paramiko.SSHClient()
                c.set_missing_host_key_policy(paramiko.AutoAddPolicy())
                try:
                    c.connect(
                        hostname=host,
                        port=int(port),
                        username=username,
                        password=password,
                        look_for_keys=False,
                        allow_agent=False,
                        timeout=20
                    )
                    try:
                        t = c.get_transport()
                        if t:
                            try:
                                t.set_keepalive(30)
                            except Exception:
                                pass
                    except Exception:
                        pass
                    self.ssh_client = c
                    self.update_status_signal.emit('重连成功')
                    self.reconnecting = False
                    return True
                except Exception as e:
                    attempt += 1
                    wait = min(2 ** attempt, 60)
                    try:
                        self.update_status_signal.emit(f'重连失败 ({attempt}/{max_retries})，{wait}秒后重试...')
                    except Exception:
                        pass
                    if self.stop_event.is_set():
                        break
                    try:
                        time.sleep(wait)
                    except Exception:
                        pass
            try:
                self.update_status_signal.emit('达到最大重试次数，放弃连接')
            except Exception:
                pass
            try:
                self.disconnect()
            except Exception:
                pass
            self.reconnecting = False
            return False
        except Exception:
            try:
                self.reconnecting = False
            except Exception:
                pass
            return False

    def disconnect(self):
        """断开SSH连接"""
        try:
            self.update_status_signal.emit('正在断开连接...')
            self.is_connected = False
            try:
                self.stop_event.set()
            except Exception:
                pass

            time.sleep(0.5)

            try:
                if self.server_socket:
                    try:
                        self.server_socket.close()
                    except Exception:
                        pass
                    self.server_socket = None
                    self.update_status_signal.emit('端口监听已关闭')
            except Exception:
                pass

            if self.ssh_client:
                try:
                    self.ssh_client.close()
                    self.update_status_signal.emit('SSH连接已关闭')
                except Exception as e:
                    self.update_status_signal.emit(f'关闭SSH连接时出错: {str(e)}')
                finally:
                    self.ssh_client = None

            try:
                if self.forward_thread:
                    # 不需要 join，直接清空引用
                    pass
                self.forward_thread = None
            except Exception:
                self.forward_thread = None

            try:
                if hasattr(self, 'client_threads') and self.client_threads:
                    # 不需要 join，直接清空列表
                    # 前面已经调用了 close()，Socket 报错会让线程自己结束
                    self.client_threads = []
                    self.update_status_signal.emit('所有客户端连接已关闭')
            except Exception:
                pass

            self.connection_status_signal.emit(False)
            self.update_status_signal.emit('连接已完全断开')
        except Exception as e:
            QMessageBox.critical(self, '错误', f'断开连接过程中出错: {str(e)}')
            self.is_connected = False
            self.ssh_client = None
            self.forward_thread = None
            self.connection_status_signal.emit(False)

    def _recreate_server_socket(self, remote_port):
        try:
            if self.server_socket:
                try:
                    self.server_socket.close()
                except Exception:
                    pass
                self.server_socket = None
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            s.bind(('127.0.0.1', remote_port))
            s.listen(5)
            s.settimeout(1)
            self.server_socket = s
            self.update_status_signal.emit(f'本地监听器已重建在端口 {remote_port}')
            return True
        except Exception as e:
            self.update_status_signal.emit(f'本地监听器重建失败: {str(e)}')
            return False

    def closeEvent(self, event):
        # 1. 立即隐藏窗口，给用户"已关闭"的反馈
        self.hide()
        event.ignore()  # 先忽略关闭事件，防止系统强制销毁导致清理未完成

        def shutdown_task():
            try:
                # 执行原本的优雅退出逻辑
                self.graceful_shutdown()
                
                # 额外的资源清理，确保释放所有文件句柄
                import gc
                gc.collect()
                
                # 关闭所有可能打开的文件
                import os
                try:
                    # 强制关闭所有可能的文件描述符（在Windows上可能不适用，但无害）
                    pass
                except Exception:
                    pass
                    
            except Exception:
                pass
            finally:
                # 清理完成后，强制退出应用程序
                QCoreApplication.quit()
                sys.exit(0)  # 强制杀掉进程，防止残留

        # 2. 开启线程执行清理
        t = threading.Thread(target=shutdown_task)
        t.start()

    def graceful_shutdown(self):
        try:
            # 并行化资源释放 - disconnect() 和 driver.quit() 互不依赖
            threads = []
            
            # 启动 disconnect 线程
            def disconnect_task():
                try:
                    self.disconnect()
                except Exception:
                    pass
            
            # 启动 driver.quit 线程
            def driver_quit_task():
                try:
                    if self.autodl_driver:
                        self.autodl_driver.quit()
                        self.autodl_driver = None
                except Exception:
                    pass
            
            # 创建并启动两个线程
            t1 = threading.Thread(target=disconnect_task)
            t2 = threading.Thread(target=driver_quit_task)
            threads = [t1, t2]
            
            for t in threads:
                t.start()
            
            # 等待两个线程完成（设置超时防止无限等待）
            for t in threads:
                try:
                    t.join(timeout=3.0)  # 最多等待3秒
                except Exception:
                    pass
            
            # 额外的资源清理，确保释放所有文件句柄
            import gc
            gc.collect()
            
            # 关闭所有可能打开的文件
            import os
            try:
                # 强制关闭所有可能的文件描述符（在Windows上可能不适用，但无害）
                pass
            except Exception:
                pass
                    
        except Exception:
            pass

    def _ensure_autodl_dependencies(self):
        try:
            global SELENIUM_AVAILABLE
            if SELENIUM_AVAILABLE:
                return True
            
            # 如果是打包后的EXE，直接返回False，不尝试安装依赖
            if is_frozen():
                self.autodl_status_signal.emit('打包环境下无法安装AutoDL依赖，请确保构建时已包含。')
                return False
            
            self.autodl_status_signal.emit('正在安装 AutoDL 依赖: selenium, webdriver-manager')
            ok = _pip_install(['selenium>=4.0.0', 'webdriver-manager>=3.0.0'])
            if not ok:
                return False
            from selenium import webdriver
            from selenium.webdriver.common.by import By
            from selenium.webdriver.support.ui import WebDriverWait
            from selenium.webdriver.support import expected_conditions as EC
            from selenium.webdriver.chrome.options import Options
            from selenium.common.exceptions import TimeoutException, NoSuchElementException, StaleElementReferenceException, ElementClickInterceptedException
            from selenium.webdriver.common.action_chains import ActionChains
            from selenium.webdriver.chrome.service import Service
            from webdriver_manager.chrome import ChromeDriverManager
            SELENIUM_AVAILABLE = True
            self.autodl_status_signal.emit('依赖安装完成，可使用 AutoDL 功能')
            return True
        except Exception as e:
            try:
                self.autodl_status_signal.emit(f'依赖安装或导入失败: {str(e)}')
            except Exception:
                pass
            return False

    def test_gpu_detection(self):
        """测试GPU设备检测功能"""
        if not self.autodl_driver or not self.is_autodl_logged_in:
            QMessageBox.warning(self, '未登录', '请先登录AutoDL')
            return
        
        def test_thread():
            try:
                self.autodl_status_signal.emit('正在测试GPU设备检测...')
                
                # 设置网页内容缩放为70%以显示更多设备
                self.autodl_driver.execute_script("document.body.style.zoom='70%'")
                time.sleep(1)
                
                # 使用专门的GPU设备检测方法
                gpu_devices = self.autodl_detect_gpu_devices()
                
                if gpu_devices:
                    self.autodl_status_signal.emit(f'GPU检测测试完成，找到 {len(gpu_devices)} 台设备')
                    # 仅输出前3条摘要，完整信息写入调试文件
                    device_info = []
                    for i, device in enumerate(gpu_devices[:3]):
                        data = device.get('data', [])
                        summary = ' | '.join(data) if isinstance(data, list) else str(data)
                        device_info.append(f"设备 {i+1}: {summary[:120]}...")
                    if device_info:
                        self.autodl_status_signal.emit("\n".join(device_info))
                    try:
                        debug = {
                            'count': len(gpu_devices),
                            'devices': gpu_devices,
                            'timestamp': time.strftime('%Y-%m-%d %H:%M:%S')
                        }
                        with open('gpu_detection_ui_debug.json', 'w', encoding='utf-8') as f:
                            json.dump(debug, f, ensure_ascii=False, indent=2)
                    except Exception:
                        pass
                    
                    # 更新设备表格显示
                    rows = []
                    for device in gpu_devices:
                        if 'row_element' in device:
                            rows.append(device['row_element'])
                        elif 'container_element' in device:
                            rows.append(device['container_element'])
                    
                    if rows:
                        table_data = self._format_rows_for_table(rows)
                        self.update_device_table_signal.emit(table_data)
                else:
                    self.autodl_status_signal.emit('未检测到GPU设备，可能页面结构已更改')
                    
                    # 获取页面信息进行调试
                    try:
                        page_title = self.autodl_driver.title
                        current_url = self.autodl_driver.current_url
                        page_source = self.autodl_driver.page_source[:500]
                        
                        debug_info = f"页面标题: {page_title}\n当前URL: {current_url}\n页面源码前500字符: {page_source}"
                        print(f"GPU检测调试信息:\n{debug_info}")
                        
                    except Exception as e:
                        print(f"获取调试信息失败: {e}")
                
            except Exception as e:
                self.autodl_status_signal.emit(f'GPU检测测试失败: {str(e)}')
                print(f"GPU检测测试详细错误: {e}")
                import traceback
                traceback.print_exc()
        
        # 在新线程中执行测试
        test_thread_obj = threading.Thread(target=test_thread)
        test_thread_obj.daemon = True
        test_thread_obj.start()


def main():
    # 设置异常处理
    def handle_exception(exc_type, exc_value, exc_traceback):
        if issubclass(exc_type, KeyboardInterrupt):
            sys.__excepthook__(exc_type, exc_value, exc_traceback)
            return
        error_msg = f'{exc_type.__name__}: {exc_value}'
        print(f'未捕获的异常: {error_msg}', file=sys.stderr)
        if QApplication.instance():
            QMessageBox.critical(None, '应用程序错误', f'发生未处理的错误:\n{error_msg}')

    # 设置全局异常钩子
    sys.excepthook = handle_exception

    try:
        print("启动SSH端口转发工具...")

        # 高分屏支持（外观）
        QCoreApplication.setAttribute(Qt.AA_EnableHighDpiScaling, True)
        QCoreApplication.setAttribute(Qt.AA_UseHighDpiPixmaps, True)

        # 在创建任何窗口之前设置 Windows AppUserModelID，以稳定任务栏图标显示
        try:
            import platform as _plat2
            if 'windows' in _plat2.system().lower():
                import ctypes
                ctypes.windll.shell32.SetCurrentProcessExplicitAppUserModelID('mingh.AutoDL_SSH_Helper')
        except Exception:
            pass

        # 创建应用程序实例
        app = QApplication(sys.argv)
        def _qt_msg_handler(_type, _context, _message):
            try:
                if 'Cannot queue arguments of type' in _message and 'QVector<int>' in _message:
                    return
            except Exception:
                pass
            try:
                print(_message)
            except Exception:
                pass
        try:
            QtCore.qInstallMessageHandler(_qt_msg_handler)
        except Exception:
            pass

        # 全局中文无衬线字体（mac 优先苹方，Win 用雅黑，Linux 用 Noto）
        import platform
        system = platform.system().lower()
        if 'darwin' in system:
            app.setFont(QFont('PingFang SC', 13))
        elif 'windows' in system:
            app.setFont(QFont('Microsoft YaHei UI', 12))
        else:
            app.setFont(QFont('Noto Sans CJK SC', 12))

        app.setApplicationName("AutoDL 一键连接")
        app.setApplicationVersion("1.1")
        import platform as _plat
        _sys = _plat.system().lower()
        if 'windows' in _sys:
            from PyQt5.QtWidgets import QStyleFactory
            try:
                app.setStyle(QStyleFactory.create('WindowsVista') or 'Windows')
            except Exception:
                app.setStyle('Windows')
            app.setPalette(app.style().standardPalette())
        else:
            app.setStyle('Fusion')

        # 全局应用图标与任务栏图标
        try:
            icon_path = None
            if hasattr(sys, '_MEIPASS'):
                p = os.path.join(sys._MEIPASS, 'assets', 'icon.ico')
                if os.path.exists(p):
                    icon_path = p
            if not icon_path:
                base_dir = os.path.dirname(sys.executable) if getattr(sys, 'frozen', False) else os.path.dirname(os.path.abspath(__file__))
                p = os.path.join(base_dir, 'assets', 'icon.ico')
                if os.path.exists(p):
                    icon_path = p
            if icon_path:
                app.setWindowIcon(QIcon(icon_path))
        except Exception:
            pass

        window = SSHPortForwarder()
        try:
            icon_path = None
            if hasattr(sys, '_MEIPASS'):
                p = os.path.join(sys._MEIPASS, 'assets', 'icon.ico')
                if os.path.exists(p):
                    icon_path = p
            if not icon_path:
                base_dir = os.path.dirname(sys.executable) if getattr(sys, 'frozen', False) else os.path.dirname(os.path.abspath(__file__))
                p = os.path.join(base_dir, 'assets', 'icon.ico')
                if os.path.exists(p):
                    icon_path = p
            if icon_path:
                window.setWindowIcon(QIcon(icon_path))
        except Exception:
            pass
        window.showMaximized()

        try:
            app.aboutToQuit.connect(window.graceful_shutdown)
        except Exception:
            pass

        try:
            import atexit
            atexit.register(lambda: hasattr(window, 'graceful_shutdown') and window.graceful_shutdown())
        except Exception:
            pass

        try:
            import signal as _sig
            def _handle_exit(*_args, **_kwargs):
                try:
                    window.graceful_shutdown()
                except Exception:
                    pass
            try:
                _sig.signal(_sig.SIGINT, _handle_exit)
            except Exception:
                pass
            try:
                _sig.signal(_sig.SIGTERM, _handle_exit)
            except Exception:
                pass
        except Exception:
            pass

        sys.exit(app.exec_())
    except Exception as e:
        print(f'应用程序启动失败: {str(e)}', file=sys.stderr)
        sys.exit(1)


# 确保应用程序可以直接执行
if __name__ == '__main__':
    main()
