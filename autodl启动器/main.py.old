            for t in self.findChildren(QToolButton):
                t.setCursor(Qt.PointingHandCursor)
        except Exception:
            pass

    def mousePressEvent(self, event):
        if event.button() == Qt.LeftButton and event.pos().y() <= 60:
            self.oldPos = event.globalPos()

    def mouseMoveEvent(self, event):
        if event.buttons() == Qt.LeftButton and self.oldPos and event.pos().y() <= 60:
            delta = QPoint(event.globalPos() - self.oldPos)
            self.move(self.x() + delta.x(), self.y() + delta.y())
            self.oldPos = event.globalPos()

    def paintEvent(self, event):
        # 只保留透明窗口，不再在这里画白底，避免覆盖边框/投影
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing)
        painter.setBrush(Qt.transparent)
        painter.setPen(Qt.NoPen)
        painter.drawRect(self.rect())


    def keyPressEvent(self, event):
        try:
            if event.key() == Qt.Key_F11:
                if self.isFullScreen():
                    self.showNormal()
                    self.showMaximized()
                else:
                    self.showFullScreen()
        except Exception:
            pass

    def apply_theme(self):
        try:
            if getattr(self, 'current_theme', 'light') == 'dark':
                self.setStyleSheet(self.DARK_STYLESHEET)
                try:
                    self.theme_button.setText('☀️')
                except Exception:
                    pass
            else:
                self.setStyleSheet(self.LIGHT_STYLESHEET)
                try:
                    self.theme_button.setText('🌙')
                except Exception:
                    pass
            try:
                self.apply_autodl_panel_theme()
            except Exception:
                pass
        except Exception:
            pass

    def setup_event_handlers(self):
        """设置事件处理程序"""
        # 支持粘贴操作
        self.ssh_info_input.textChanged.connect(self.auto_parse_ssh_info)
        # 配置管理事件处理
        self.save_config_button.clicked.connect(self.save_config)
        self.delete_config_button.clicked.connect(self.delete_config)
        self.delete_all_button.clicked.connect(self.delete_all_configs)
        self.config_combo.currentIndexChanged.connect(self.load_selected_config)
        self.config_combo.currentIndexChanged.connect(self.update_delete_button_state)
        
        # 密码显示切换
        self.show_password_checkbox.stateChanged.connect(self.toggle_password_visibility)
        
        # 状态信号连接（只连接一次，避免重复）
        try:
            self.update_status_signal.disconnect(self.update_status)
        except Exception:
            pass
        self.update_status_signal.connect(self.update_status)

        try:
            self.connection_status_signal.disconnect(self.update_connection_status)
        except Exception:
            pass
        self.connection_status_signal.connect(self.update_connection_status)

        try:
            self.autodl_status_signal.disconnect(self.update_autodl_status)
        except Exception:
            pass
        self.autodl_status_signal.connect(self.update_autodl_status)

        try:
            self.autodl_login_signal.disconnect(self.update_autodl_login_status)
        except Exception:
            pass
        self.autodl_login_signal.connect(self.update_autodl_login_status)

        # AutoDL事件处理
        if SELENIUM_AVAILABLE:
            self.autodl_login_button.clicked.connect(lambda: self.autodl_login(None))
            self.autodl_logout_button.clicked.connect(self.autodl_logout)
            self.autodl_refresh_button.clicked.connect(self.autodl_refresh_devices)
            # 连接设备表格更新信号
            self.update_device_table_signal.connect(self.update_device_table)

            try:
                self.visible_radio.toggled.connect(self._persist_login_prefs)
                self.headless_radio.toggled.connect(self._persist_login_prefs)
                self.auto_login_checkbox.toggled.connect(self._persist_login_prefs)
                self.silent_refresh_checkbox.toggled.connect(self._persist_login_prefs)
            except Exception:
                pass

    def create_autodl_panel(self):
        """创建AutoDL控制面板"""
        panel = QWidget()
        panel.setObjectName('autodlPanel')
        self.autodl_panel = panel
        self.apply_autodl_panel_theme()
        
        layout = QVBoxLayout(panel)
        layout.setContentsMargins(8, 8, 8, 8)
        layout.setSpacing(6)
        
        # 标题和控制按钮
        title_layout = QHBoxLayout()
        title_layout.setSpacing(8)
        
        title_label = QLabel('AutoDL 设备管理')
        title_label.setStyleSheet('font-weight: 700; font-size: 11pt;')
        title_layout.addWidget(title_label)
        title_layout.addStretch()
        
        # 登录状态
        self.autodl_status_label = QLabel('未登录')
        self.autodl_status_label.setStyleSheet('color: #656d76; font-size: 9pt;')
        title_layout.addWidget(self.autodl_status_label)
        
        
        
        layout.addLayout(title_layout)
        
        # 登录区域
        login_layout = QHBoxLayout()
        login_layout.setSpacing(6)
        
        self.autodl_username_input = QLineEdit()
        self.autodl_username_input.setPlaceholderText('AutoDL用户名')
        self.autodl_username_input.setMinimumWidth(220)
        self.autodl_username_input.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)
        login_layout.addWidget(self.autodl_username_input, 2)
        
        self.autodl_password_input = QLineEdit()
