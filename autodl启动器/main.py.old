    def autodl_forward_only(self, device_id=None, remark=None):
        try:
            if self.autodl_busy:
                self.autodl_status_signal.emit('正在执行任务，请稍候...')
                return
        except Exception:
            pass
        def forward_thread():
            try:
                if self.is_connected:
                    self.autodl_status_signal.emit('已连接，忽略重复连接请求')
                    return
                if self.is_connecting:
                    self.autodl_status_signal.emit('正在连接中，请稍候')
                    return
                did = device_id
                rem = remark
                connected = False
                try:
                    connected = bool(self._connect_using_device_config(did))
                except Exception:
                    connected = False
                if not connected:
                    try:
                        self.autodl_status_signal.emit('尝试从网页复制登录信息并连接...')
                        self._try_copy_and_connect(did, rem)
                    except Exception:
                        pass
            except Exception as e:
                self.autodl_status_signal.emit(f'连接失败: {str(e)}')
            finally:
                try:
                    self.autodl_busy = False
                except Exception:
                    pass
                try:
                    self.autodl_status_signal.emit('连接任务完成')
                except Exception:
                    pass
        self.autodl_busy = True
        t = threading.Thread(target=forward_thread)
        t.daemon = True
        t.start()

    def autodl_start_nogpu(self, device_id=None, remark=None):
        try:
            if self.autodl_busy:
                self.autodl_status_signal.emit('正在执行任务，请稍候...')
                return
        except Exception:
            pass
        def start_thread():
            try:
                self.autodl_status_signal.emit(f'准备无卡开机: device_id={device_id or "<空>"}, 备注={remark or "<空>"}')
                self._goto_instance_list()
                row = None
                if device_id and len(device_id) >= 6:
                    try:
                        row = self._find_row_by_device_id(device_id)
                    except Exception:
                        row = None
                if row is None and remark:
                    try:
                        row = self._find_row_by_remark(remark)
                    except Exception:
                        row = None
                if row is None:
                    raise NoSuchElementException('未定位到设备行')
                # 不再自动预关机，尊重当前状态；点击过程失败也不立即失败，进入结果监控
                self.autodl_driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", row)
                time.sleep(0.2)
                did = device_id or self._extract_id_from_row(row)
                rem = remark or self._extract_remark_from_row(row)
                try:
                    self.await_running_device_id = did
                    self.await_running_remark = rem
                    if hasattr(self, 'autodl_auto_refresh_timer'):
                        self.autodl_auto_refresh_timer.setInterval(1500)
                except Exception:
                    pass
                click_sent = False
                try:
                    click_sent = bool(self._start_nogpu_by_row(row))
                except Exception:
                    self.autodl_status_signal.emit('无卡开机点击动作异常，进入状态监控')
                if click_sent:
                    self.autodl_status_signal.emit('无卡开机指令已发送')
                else:
                    self.autodl_status_signal.emit('未确认点击成功，继续监控状态变化')
                r_run = self._wait_for_running_nogpu(device_id=did, remark=rem, timeout=300, interval=4)
                if r_run:
                    self.autodl_status_signal.emit('设备已运行（无卡模式）')
                    try:
                        self.await_running_device_id = None
                        self.await_running_remark = None
                        if hasattr(self, 'autodl_auto_refresh_timer'):
                            self.autodl_auto_refresh_timer.setInterval(30000)
                    except Exception:
                        pass
                else:
                    self.autodl_status_signal.emit('无卡开机后状态未切换为运行中或未显示无卡模式')
                self.autodl_refresh_devices_quick()
            except NoSuchElementException:
                self.autodl_status_signal.emit('无卡开机失败：未找到更多菜单或设备行')
            except TimeoutException:
                self.autodl_status_signal.emit('无卡开机确认超时')
            except Exception as e:
                self.autodl_status_signal.emit(f'无卡开机失败: {str(e)}')
            finally:
                try:
                    self.autodl_busy = False
                except Exception:
                    pass
                try:
                    if 'r_run' in locals() and r_run:
                        self.autodl_status_signal.emit('无卡开机任务完成')
                except Exception:
                    pass
        self.autodl_busy = True
        t = threading.Thread(target=start_thread)
        t.daemon = True
        t.start()

    def autodl_connect_device(self, device_id=None, remark=None):
        try:
            if self.autodl_busy:
                self.autodl_status_signal.emit('正在执行任务，请稍候...')
                return
        except Exception:
            pass
        def connect_thread():
            try:
                if self.is_connected:
                    self.autodl_status_signal.emit('已连接，忽略重复连接请求')
                    return
                if self.is_connecting:
                    self.autodl_status_signal.emit('正在连接中，请稍候')
                    return
                did = device_id
                rem = remark
                try:
                    self.autodl_status_signal.emit('正在点击JupyterLab...')
                    self.autodl_click_jupyterlab(did, rem)
                except Exception:
                    pass
                connected = False
                try:
                    connected = bool(self._connect_using_device_config(did))
                except Exception:
                    connected = False
                if not connected:
                    try:
                        self.autodl_status_signal.emit('尝试从网页复制登录信息并连接...')
                        self._try_copy_and_connect(did, rem)
                    except Exception:
                        pass
            except Exception as e:
                self.autodl_status_signal.emit(f'连接失败: {str(e)}')
            finally:
                try:
                    self.autodl_busy = False
                except Exception:
                    pass
                try:
                    self.autodl_status_signal.emit('连接任务完成')
                except Exception:
                    pass
        self.autodl_busy = True
        t = threading.Thread(target=connect_thread)
        t.daemon = True
        t.start()

    def autodl_stop_by_id(self, device_id):
        try:
            if self.autodl_busy:
                self.autodl_status_signal.emit('正在执行任务，请稍候...')
                return
        except Exception:
            pass
        def stop_thread():
            try:
                self._goto_instance_list()
                row = self._find_row_by_device_id(device_id)
                self.autodl_driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", row)
                time.sleep(0.3)
                remark = self._extract_remark_from_row(row)
                did = device_id or self._extract_id_from_row(row)
                self.autodl_status_signal.emit('正在确认关机...')
                ok_click = self._stop_by_row(row)
                if not ok_click:
                    raise Exception('关机点击失败')
                self.autodl_status_signal.emit('关机指令已发送')
                def wait_for_stopped(timeout=120, interval=5):
                    start_t = time.time()
                    while time.time() - start_t < timeout:
                        try:
                            self._goto_instance_list()
                            r = None
                            if did:
                                try:
                                    r = self._find_row_by_device_id(did)
                                except Exception:
                                    r = None
                            if r is None and remark:
                                try:
                                    r = self._find_row_by_remark(remark)
                                except Exception:
                                    r = None
                            if r is None:
                                self.autodl_refresh_devices_quick(True)
                                time.sleep(interval)
                                continue
                            tds2 = r.find_elements(By.TAG_NAME, 'td')
                            st = tds2[1].text if len(tds2) >= 2 else r.text
                            stl = st.lower()
                            if ('已关机' in st) or ('stopped' in stl):
                                return True
                            if any(k in st for k in ['关机中','正在关机','停止中','关闭中']) or any(k in stl for k in ['shutting','stopping']):
                                self.autodl_refresh_devices_quick(True)
                                time.sleep(interval)
                                continue
                            self.autodl_refresh_devices_quick(True)
                            time.sleep(interval)
                        except Exception:
                            self.autodl_refresh_devices_quick(True)
                            time.sleep(interval)
                    return False
                ok = wait_for_stopped()
                if ok:
                    self.autodl_status_signal.emit('设备已关机')
                    try:
                        self.disconnect()
                    except Exception:
                        pass
                else:
                    self.autodl_status_signal.emit('关机状态未切换为已关机')
                self.autodl_refresh_devices_quick()
            except StaleElementReferenceException:
                try:
                    row = self.autodl_driver.find_element(By.XPATH, f"//*[contains(normalize-space(.), '{device_id}')]//ancestor::tr[1]")
                    tds = row.find_elements(By.TAG_NAME, 'td')
                    action_td = tds[-1] if tds else row
                    btn = action_td.find_element(By.XPATH, ".//a[contains(normalize-space(), '关机')] | .//button[.//span[contains(normalize-space(), '关机')]]")
                    self.autodl_driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", btn)
                    btn.click()
                except Exception as e:
                    self.autodl_status_signal.emit(f'关机失败: {str(e)}')
            except NoSuchElementException:
                self.autodl_status_signal.emit('关机失败：未找到关机按钮或设备行')
            except TimeoutException:
                self.autodl_status_signal.emit('确认关机超时')
            except Exception as e:
                self.autodl_status_signal.emit(f'关机失败: {str(e)}')
            finally:
                try:
                    self.autodl_busy = False
                except Exception:
                    pass
                try:
                    if 'ok' in locals() and ok:
                        self.autodl_status_signal.emit('关机任务完成')
                except Exception:
                    pass
        self.autodl_busy = True
        t = threading.Thread(target=stop_thread)
        t.daemon = True
        t.start()

    def autodl_stop(self, device_id=None, remark=None):
        try:
            if self.autodl_busy:
                self.autodl_status_signal.emit('正在执行任务，请稍候...')
                return
        except Exception:
            pass
        def stop_thread():
            try:
                self.autodl_status_signal.emit(f'准备关机: device_id={device_id or "<空>"}, 备注={remark or "<空>"}')
                self._goto_instance_list()
                row = None
                if device_id and len(device_id) >= 6:
                    try:
                        row = self._find_row_by_device_id(device_id)
                    except Exception:
                        row = None
                if row is None and remark:
                    try:
                        row = self._find_row_by_remark(remark)
                    except Exception:
                        row = None
                if row is None:
                    raise NoSuchElementException('未定位到设备行')
                self.autodl_driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", row)
                time.sleep(0.3)
                did = device_id or self._extract_id_from_row(row)
                rem = remark or self._extract_remark_from_row(row)
                self.autodl_status_signal.emit('正在确认关机...')
                ok_click = self._stop_by_row(row)
                if not ok_click:
                    raise Exception('关机点击失败')
                self.autodl_status_signal.emit('关机指令已发送')
                def wait_for_stopped(timeout=120, interval=5):
                    start_t = time.time()
                    while time.time() - start_t < timeout:
                        try:
                            self._goto_instance_list()
                            r = None
                            if did:
                                try:
                                    r = self._find_row_by_device_id(did)
                                except Exception:
                                    r = None
                            if r is None and rem:
                                try:
                                    r = self._find_row_by_remark(rem)
                                except Exception:
                                    r = None
                            if r is None:
                                self.autodl_refresh_devices_quick(True)
                                time.sleep(interval)
                                continue
                            tds2 = r.find_elements(By.TAG_NAME, 'td')
                            st = tds2[1].text if len(tds2) >= 2 else r.text
                            stl = st.lower()
                            if ('已关机' in st) or ('stopped' in stl):
                                return True
                            if any(k in st for k in ['关机中','正在关机','停止中','关闭中']) or any(k in stl for k in ['shutting','stopping']):
                                self.autodl_refresh_devices_quick(True)
                                time.sleep(interval)
                                continue
                            self.autodl_refresh_devices_quick(True)
                            time.sleep(interval)
                        except Exception:
                            self.autodl_refresh_devices_quick(True)
                            time.sleep(interval)
                    return False
                ok = wait_for_stopped()
                if ok:
                    self.autodl_status_signal.emit('设备已关机')
                    try:
                        self.disconnect()
                    except Exception:
                        pass
                else:
                    self.autodl_status_signal.emit('关机状态未切换为已关机')
                self.autodl_refresh_devices_quick()
            except NoSuchElementException:
                self.autodl_status_signal.emit('关机失败：未找到关机按钮或设备行')
            except TimeoutException:
                self.autodl_status_signal.emit('确认关机超时')
            except Exception as e:
                self.autodl_status_signal.emit(f'关机失败: {str(e)}')
            finally:
                try:
                    self.autodl_busy = False
                except Exception:
                    pass
                try:
                    if 'ok' in locals() and ok:
                        self.autodl_status_signal.emit('关机任务完成')
                except Exception:
                    pass
        self.autodl_busy = True
        t = threading.Thread(target=stop_thread)
        t.daemon = True
        t.start()
    
    

    def auto_parse_ssh_info(self):
        """自动解析粘贴的SSH信息"""
        ssh_info = self.ssh_info_input.text().strip()
        if ssh_info:
            port_pattern = r'-L\s+(\d+):localhost:\d+'
            match = re.search(port_pattern, ssh_info)
            if match and not self.remote_port_input.text():
                self.remote_port_input.setText(match.group(1))

    def update_status(self, message):
        """更新状态日志"""
        try:
            current_text = self.log_text.toPlainText()
            lines = current_text.split('\n')
            if lines and lines[-1].endswith(message):
                return
        except Exception:
            pass
        timestamp = time.strftime('%H:%M:%S')
        self.log_text.append(f'[{timestamp}] [SSH] {message}')
        try:
            self.log_text.verticalScrollBar().setValue(self.log_text.verticalScrollBar().maximum())
        except Exception:
            pass

    def update_connection_status(self, is_connected):
        """更新连接状态"""
        self.is_connected = is_connected
        if is_connected:
            self.status_label.setText('状态: 已连接')
            self.status_label.setStyleSheet('font-weight: 700; color: #2ea043; font-size: 13.2pt;')
            self.connect_button.setEnabled(False)
            self.disconnect_button.setEnabled(True)
        else:
            self.status_label.setText('状态: 未连接')
            self.status_label.setStyleSheet('font-weight: 700; color: #656d76; font-size: 13.2pt;')
            self.connect_button.setEnabled(True)
            self.disconnect_button.setEnabled(False)

    def update_delete_button_state(self):
        """根据选中的配置更新删除按钮状态"""
        config_name = self.config_combo.currentText()
        if config_name == '当前输入配置':
            self.delete_config_button.setEnabled(False)
        else:
            self.delete_config_button.setEnabled(True)

    def toggle_connection(self):
        """切换连接状态"""
        if not self.is_connected:
            self.connect()

    def parse_ssh_info(self, ssh_info):
        """解析SSH连接信息"""
        try:
            clean_info = ssh_info.strip()
            tokens = shlex.split(clean_info)
            port = '22'
            user = None
            host = None

            for i, t in enumerate(tokens):
                if t == '-p' and i + 1 < len(tokens):
                    if re.match(r'^\d{1,5}$', tokens[i+1]):
                        port = tokens[i+1]
                if '@' in t and not user and not host:
                    u, h = t.split('@', 1)
                    if u and h:
                        user = u
                        host = h

            if not user or not host:
                m = re.search(r'([\w.-]+)@([\w.-]+)', clean_info)
                if m:
                    user = m.group(1)
                    host = m.group(2)

            if user and host:
                return host, port, user
        except Exception as e:
            self.update_status_signal.emit(f'解析SSH信息时出错: {str(e)}')

        return None, None, None

    def save_config(self):
        """保存当前配置，增强错误处理"""
        if not self.config_dir:
            QMessageBox.warning(self, '配置错误', '配置目录不可用，无法保存配置')
            return

        ssh_info = self.ssh_info_input.text().strip()
        remote_port = self.remote_port_input.text().strip()
        password = self.password_input.text()
        auto_open_browser = self.auto_open_browser_checkbox.isChecked()

        if not ssh_info:
            QMessageBox.warning(self, '输入错误', '请输入SSH连接信息')
            return

        if not remote_port:
            QMessageBox.warning(self, '输入错误', '请输入远程端口')
            return

        try:
            port_num = int(remote_port)
            if port_num <= 0 or port_num > 65535:
                raise ValueError()
        except ValueError:
            QMessageBox.warning(self, '输入错误', '请输入有效的端口号（1-65535）')
            return

        config_name, ok = QInputDialog.getText(self, '保存配置', '请输入配置名称:')
        if not ok or not config_name.strip():
            return

        config_name = config_name.strip()

        if not re.match(r'^[\w\-\_]+$', config_name):
            QMessageBox.warning(self, '名称错误', '配置名称只能包含字母、数字、下划线和连字符')
            return

        config_data = {
            'ssh_info': ssh_info,
            'remote_port': remote_port,
            'password': password,
            'auto_open_browser': auto_open_browser,
            'saved_at': time.strftime('%Y-%m-%d %H:%M:%S')
        }

        try:
            if password:
                if self.encryption_enabled:
                    enc = _win_dpapi_encrypt(password)
                    if enc:
                        config_data['password'] = enc
                else:
                    if (not self.encryption_prompted) and self._is_ui_thread():
                        reply = QMessageBox.question(self, '启用密码加密', '是否启用密码加密并以加密形式保存？（仅首次提示）', QMessageBox.Yes | QMessageBox.No, QMessageBox.No)
                        self._set_encryption_prompted(True)
                        if reply == QMessageBox.Yes:
                            self._set_encryption_pref(True)
                            enc = _win_dpapi_encrypt(password)
                            if enc:
                                config_data['password'] = enc
        except Exception:
            pass

        config_file = os.path.join(self.config_dir, f'{config_name}.json')

        if os.path.exists(config_file):
            reply = QMessageBox.question(self, '确认覆盖',
                                         f'配置 "{config_name}" 已存在，是否覆盖？',
                                         QMessageBox.Yes | QMessageBox.No, QMessageBox.No)
            if reply != QMessageBox.Yes:
                return

        try:
            os.makedirs(self.config_dir, exist_ok=True)
            with open(config_file, 'w', encoding='utf-8') as f:
                json.dump(config_data, f, ensure_ascii=False, indent=2)

            QMessageBox.information(self, '保存成功', f'配置 "{config_name}" 已成功保存')
            self.load_config_list()
            index = self.config_combo.findText(config_name)
            if index >= 0:
                self.config_combo.setCurrentIndex(index)
        except PermissionError:
            QMessageBox.critical(self, '保存失败', f'没有权限写入配置文件: {config_file}')
        except IOError as e:
            QMessageBox.critical(self, '保存失败', f'IO错误: {str(e)}')
        except Exception as e:
            QMessageBox.critical(self, '保存失败', f'保存配置时出错: {str(e)}')

    def load_config_list(self):
        """加载保存的配置列表，增强错误处理"""
        try:
            self.config_combo.clear()
            self.config_combo.addItem('当前输入配置')

            if not self.config_dir or not os.path.exists(self.config_dir):
                return

            config_files = []
            try:
                config_files = [f for f in os.listdir(self.config_dir) if f.endswith('.json')]
            except PermissionError:
                self.update_status_signal.emit(f'警告: 没有权限访问配置目录')
                return
            except Exception as e:
                self.update_status_signal.emit(f'警告: 读取配置目录时出错: {str(e)}')
                return

            for config_file in sorted([f for f in config_files if f != 'device_map.json']):
                try:
                    full_path = os.path.join(self.config_dir, config_file)
                    display_name = os.path.splitext(config_file)[0]
                    with open(full_path, 'r', encoding='utf-8') as f:
                        data = json.load(f)
                        if isinstance(data, dict) and data.get('remark'):
                            display_name = str(data.get('remark'))
                    self.config_combo.addItem(display_name)
                    idx = self.config_combo.count() - 1
                    self.config_combo.setItemData(idx, os.path.splitext(config_file)[0])
                except Exception:
                    self.config_combo.addItem(os.path.splitext(config_file)[0])
        except Exception as e:
            self.update_status_signal.emit(f'加载配置列表时出错: {str(e)}')

    def load_selected_config(self, index):
        """加载选中的配置，增强错误处理和数据验证"""
        if index <= 0:
            return

        # 优先使用条目数据中的文件名（不影响显示名为备注）
        file_key = self.config_combo.itemData(index)
        config_name = file_key if file_key else self.config_combo.currentText()
        if not config_name or (not file_key and config_name == '当前输入配置'):
            return

        if not self.config_dir:
            QMessageBox.warning(self, '配置错误', '配置目录不可用')
            self.config_combo.setCurrentIndex(0)
            return

        config_file = os.path.join(self.config_dir, f'{config_name}.json')

        if not os.path.exists(config_file):
            QMessageBox.warning(self, '文件不存在', f'配置文件不存在: {config_name}')
            self.load_config_list()
            return

        try:
            with open(config_file, 'r', encoding='utf-8') as f:
                config_data = json.load(f)

            if not isinstance(config_data, dict):
                raise ValueError('配置文件格式错误')

            self.ssh_info_input.setText(str(config_data.get('ssh_info', '')))
            self.remote_port_input.setText(str(config_data.get('remote_port', '')))
            pwd_val = str(config_data.get('password', ''))
            try:
                dec = _win_dpapi_decrypt(pwd_val)
                if dec is not None:
                    pwd_val = dec
            except Exception:
                pass
            self.password_input.setText(pwd_val)
            self.auto_open_browser_checkbox.setChecked(bool(config_data.get('auto_open_browser', True)))

            saved_time = config_data.get('saved_at', '未知')
            remark = str(config_data.get('remark', config_name))
            self.update_status_signal.emit(f'已加载配置: {remark} (保存时间: {saved_time})')
        except json.JSONDecodeError:
            QMessageBox.critical(self, '加载失败', f'配置文件格式错误: {config_name}')
        except PermissionError:
            QMessageBox.critical(self, '加载失败', f'没有权限读取配置文件')
        except Exception as e:
            QMessageBox.critical(self, '加载失败', f'加载配置时出错: {str(e)}')
        finally:
            if self.config_combo.currentIndex() <= 0:
                return

    def delete_config(self):
        """删除选中的配置，增强错误处理"""
        idx = self.config_combo.currentIndex()
        file_key = self.config_combo.itemData(idx)
        config_name = file_key if file_key else self.config_combo.currentText()
        if not config_name or config_name == '当前输入配置':
            QMessageBox.warning(self, '选择错误', '请先选择要删除的配置')
            return

        if not self.config_dir:
            QMessageBox.warning(self, '配置错误', '配置目录不可用')
            self.config_combo.setCurrentIndex(0)
            return

        display_name = self.config_combo.currentText()
        reply = QMessageBox.question(self, '确认删除',
                                     f'确定要删除配置 "{display_name}" 吗？\n此操作不可撤销。',
                                     QMessageBox.Yes | QMessageBox.No, QMessageBox.No)

        if reply != QMessageBox.Yes:
            return

        config_file = os.path.join(self.config_dir, f'{config_name}.json')

        try:
            if os.path.exists(config_file):
                try:
                    os.remove(config_file)
                    QMessageBox.information(self, '删除成功', f'配置 "{config_name}" 已成功删除')
                    self.load_config_list()
                    self.ssh_info_input.clear()
                    self.remote_port_input.clear()
                    self.password_input.clear()
                except PermissionError:
                    QMessageBox.critical(self, '删除失败', '没有权限删除配置文件')
                except OSError as e:
                    QMessageBox.critical(self, '删除失败', f'系统错误: {str(e)}')
            else:
                QMessageBox.warning(self, '文件不存在', '配置文件不存在或已被删除')
                self.load_config_list()
        except Exception as e:
            QMessageBox.critical(self, '删除失败', f'删除配置时出错: {str(e)}')
        finally:
            if self.config_combo.count() > 0:
                self.config_combo.setCurrentIndex(0)

    def delete_all_configs(self):
        try:
            if not self.config_dir or not os.path.exists(self.config_dir):
                QMessageBox.warning(self, '无配置', '配置目录不存在')
                return
            reply = QMessageBox.question(self, '确认删除', '确定要删除全部保存的连接信息吗？此操作不可撤销。', QMessageBox.Yes | QMessageBox.No, QMessageBox.No)
            if reply != QMessageBox.Yes:
                return
            for f in os.listdir(self.config_dir):
                if f.endswith('.json'):
                    try:
                        os.remove(os.path.join(self.config_dir, f))
                    except Exception:
                        pass
            try:
                if os.path.exists(self.device_map_file):
                    os.remove(self.device_map_file)
            except Exception:
                pass
            self.load_config_list()
            QMessageBox.information(self, '已删除', '已删除全部保存的连接信息')
        except Exception as e:
            QMessageBox.critical(self, '失败', f'删除全部配置失败: {str(e)}')

    def toggle_password_visibility(self, state):
        """切换密码显示/隐藏"""
        if state == Qt.Checked:
            self.password_input.setEchoMode(QLineEdit.Normal)
        else:
            self.password_input.setEchoMode(QLineEdit.Password)

    def toggle_theme(self):
        if getattr(self, 'current_theme', 'light') == 'light':
            self.current_theme = 'dark'
        else:
            self.current_theme = 'light'
        try:
            self.apply_theme()
        except Exception:
            pass
        try:
            self._persist_login_prefs()
        except Exception:
            pass
        try:
            self._save_theme_pref()
        except Exception:
            pass

