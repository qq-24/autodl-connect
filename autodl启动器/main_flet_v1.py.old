        self.apply_theme()
        
        # 主容器
        self.main_container = ft.Container(
            expand=True,
            padding=20,
            bgcolor=self.theme_colors['background']
        )
        
        # 主卡片
        self.content_card = ft.Container(
            expand=True,
            border_radius=15,
            border=ft.border.all(2, self.theme_colors['border']),
            bgcolor=self.theme_colors['card_background'],
            shadow=ft.BoxShadow(
                spread_radius=1,
                blur_radius=15,
                color=ft.Colors.BLACK54,
                offset=ft.Offset(0, 3)
            )
        )
        
        # 标题栏
        self.title_bar = ft.Container(
            height=60,
            border_radius=ft.border_radius.only(top_left=15, top_right=15),
            bgcolor=self.theme_colors['title_bar'],
            border=ft.border.only(bottom=ft.border.BorderSide(1, self.theme_colors['border'])),
            content=ft.Row([
                ft.Text(
                    "AutoDL 一键连接",
                    size=24,
                    weight=ft.FontWeight.BOLD,
                    color=self.theme_colors['text']
                ),
                ft.Container(expand=True),
                ft.IconButton(
                    icon=ft.Icons.DARK_MODE if self.current_theme == 'light' else ft.Icons.LIGHT_MODE,
                    on_click=self.toggle_theme,
