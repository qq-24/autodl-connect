    import paramiko
except ImportError:
    if not is_frozen() and _pip_install(['paramiko>=2.7.0']):
        import paramiko
    else:
        if is_frozen():
            raise ImportError("Critical: paramiko is missing in the frozen application.")
        else:
            raise

