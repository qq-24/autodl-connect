                ),
                ft.IconButton(
                    icon=ft.Icons.HELP_OUTLINE,
                    on_click=self.open_readme,
                    tooltip="打开帮助文档"
                )
            ], alignment=ft.MainAxisAlignment.START)
        )
        
        # 主体内容区域
        self.body_content = ft.Container(
            expand=True,
            padding=20,
            content=ft.Row([
                # 左侧面板
                self.create_left_panel(),
                ft.VerticalDivider(width=2, color=self.theme_colors['divider']),
                # 右侧面板
                self.create_right_panel()
            ], expand=True, spacing=20)
        )
        
        # 组装主布局
        self.content_card.content = ft.Column([
            self.title_bar,
            self.body_content
        ], spacing=0)
        
        self.main_container.content = self.content_card
        
        # 设置页面
        self.page.add(self.main_container)
        self.page.update()

